<Window x:Class="WpfAppExample.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfAppExample"
        mc:Ignorable="d"
        Title="LoginWindow" Height="278.017" Width="422.414" Background="#FFC1F4F9">
    <Grid>
        <TextBlock Text="用户登录" HorizontalAlignment="Left" Margin="166,14,0,0" TextWrapping="Wrap"  VerticalAlignment="Top" FontFamily="Segoe Print" FontSize="20" TextDecorations="Underline" Foreground="#FFFB1616"/>
