<Window x:Class="WpfApp240930.WindowCalc"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp240930"
        mc:Ignorable="d"
        Title="WindowCalc" Height="364.655" Width="608.621">
    <Grid>
        
        <GroupBox Header="计算" HorizontalAlignment="Left" Height="144" Margin="40,145,0,0" VerticalAlignment="Top" Width="532">
            <WrapPanel HorizontalAlignment="Left" Height="100" Margin="5,13,0,0" VerticalAlignment="Top" Width="510">
                <TextBox Height="23" TextWrapping="Wrap" Text="" Width="70" Margin="20" Name="txtNumber1"/>
                <TextBlock TextWrapping="Wrap" Text="+" Margin="20" Name="lblop"/>
                <TextBox Height="23" TextWrapping="Wrap" Text="" Width="70" Margin="20" x:Name="txtNumber2"/>
                <TextBlock TextWrapping="Wrap" Text="=" Margin="20"/>
                <TextBlock TextWrapping="Wrap" Text="" Margin="20" Name="tblresult"/>
                <Button Content="计算" Width="60" Margin="20" Click="Button_Click"/>
            </WrapPanel>
        </GroupBox>
        <GroupBox Header="选择运算类型" HorizontalAlignment="Left" Height="86" Margin="38,24,0,0" VerticalAlignment="Top" Width="534">
            <WrapPanel HorizontalAlignment="Left" Height="49" Margin="18,7,0,0" VerticalAlignment="Top" Width="446">
                <RadioButton Name="rbtAdd" Content="加法" Margin="10" IsChecked="True" Checked="RadioButton_Checked"/>
                <RadioButton Name="rbtSub" Content="减法" Margin="10" Checked="RbtSub_Checked"/>
            </WrapPanel>
        </GroupBox>
    </Grid>
</Window>
