<Window x:Class="E01_BaseControlExample.RadioandCheckBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:E01_BaseControlExample"
        mc:Ignorable="d"
        Title="RadioandCheckBox" Height="450" Width="642.657">
    <Grid>
        <WrapPanel Height="50" Orientation="Horizontal" VerticalAlignment="Top" Margin="92,50,349.333,0">
            <Label Content="性别："></Label>
            <RadioButton Margin="3" IsChecked="True">男</RadioButton>
            <RadioButton Margin="3" >女</RadioButton>
        </WrapPanel>
        <GroupBox Header="参赛项目" BorderBrush="Green" BorderThickness="1" Margin="51,140,238,213.667">
            <WrapPanel Name="wp1">
                <CheckBox Content="篮球" Checked="CheckBox_Checked" Click="CheckBox_Click"/>
                <CheckBox Content="足球" Checked="CheckBox_Checked" Click="CheckBox_Click"/>
                <CheckBox Content="排球" Checked="CheckBox_Checked" Click="CheckBox_Click"/>
                <CheckBox Content="乒乓球" Checked="CheckBox_Checked" Click="CheckBox_Click"/>
                <CheckBox Content="跳绳" Checked="CheckBox_Checked" Click="CheckBox_Click"/>
            </WrapPanel>
        </GroupBox>
        <TextBlock x:Name="tbResult" HorizontalAlignment="Left" Margin="64,274,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top"/>

    </Grid>
</Window>
