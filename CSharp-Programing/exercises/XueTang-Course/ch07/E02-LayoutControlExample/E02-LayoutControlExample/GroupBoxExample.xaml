<Window x:Class="E02_LayoutControlExample.GroupBoxExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:E02_LayoutControlExample"
        mc:Ignorable="d"
        Title="GroupBoxExample" Height="450" Width="800">
    <Grid>
        <GroupBox  Header="GroupBox演示" Margin="101,112,559.333,190.667" BorderBrush="Green" BorderThickness="2">
            <TextBlock Text="Hello"/>
        </GroupBox>
        <GroupBox  Header="比赛项目"
                  Background="Beige" BorderBrush="Red" BorderThickness="2" Margin="305,112,275.333,190.667">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                <RadioButton Content="篮球" Margin="3"/>
                <RadioButton Content="足球" Margin="3"/>
                <RadioButton Content="网球" Margin="3"/>
                <RadioButton Content="乒乓球" Margin="3"/>
            </StackPanel>
        </GroupBox>

    </Grid>
</Window>
