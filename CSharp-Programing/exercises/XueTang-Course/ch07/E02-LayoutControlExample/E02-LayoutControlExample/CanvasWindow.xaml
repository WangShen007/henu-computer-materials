<Window x:Class="E02_LayoutControlExample.CanvasWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:E02_LayoutControlExample"
        mc:Ignorable="d"
        Title="CanvasWindow" Height="450" Width="800">
    <Grid>
    <Canvas Background="#FFFBF0E2" Margin="144,35,163,70">
        <Ellipse  Canvas.Left="78" Canvas.Top="5" Width="100" Height="100" Fill="Yellow"/>
            <Rectangle Width="100" Height="100" Canvas.Left="240" Canvas.Top="5" Fill="Blue"></Rectangle>
            <Ellipse  Canvas.ZIndex="3" Canvas.Left="10" Width="100" Height="100" Canvas.Top="150" Fill="Orange"/>
            <Ellipse Canvas.ZIndex="2" Canvas.Left="60" Width="100" Height="100" Canvas.Top="150" Fill="OrangeRed"/>
            <Ellipse Canvas.ZIndex="1" Canvas.Left="110" Width="100" Height="100" Canvas.Top="150" Fill="Green"/>
            <Ellipse Canvas.ZIndex="0" Canvas.Left="160" Width="100" Height="100" Canvas.Top="150" Fill="GreenYellow"/>
            <Ellipse Canvas.ZIndex="-1" Canvas.Left="210" Width="100" Height="100" Canvas.Top="150" Fill="BlueViolet"/>
    </Canvas>
    </Grid>
</Window>
