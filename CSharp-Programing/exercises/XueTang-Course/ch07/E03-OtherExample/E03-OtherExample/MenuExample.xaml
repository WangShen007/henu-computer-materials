<Window x:Class="E03_OtherExample.MenuExample"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:E03_OtherExample"
        mc:Ignorable="d"
        Title="MenuExample" Height="244.106" Width="800">
    <Grid>
        <StackPanel Margin="0,0,0.333,-0.333">
            <GroupBox Header="例1">
                <StackPanel Height="177" Margin="0,0,0.333,0">
                    <Menu>
                        <MenuItem Header="文件">
                            <MenuItem Header="新建(_N)" InputGestureText="Ctrl+N">
                            </MenuItem>
                            <MenuItem Header="打开(_O)" InputGestureText="Ctrl+O">
                            </MenuItem>
                            <Separator />
                            <MenuItem Header="保存(_S)" InputGestureText="Ctrl+S">
                                <MenuItem.Icon>
                                    <Image Source="/Resources/save.png" />
                                </MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="另存为..." />
                            <Separator />
                            <MenuItem Header="退出(_X)" />
                        </MenuItem>
                        <MenuItem Header="编辑(_E)">
                            <MenuItem Command="ApplicationCommands.Copy">

                            </MenuItem>
                            <MenuItem Command="ApplicationCommands.Cut">

                            </MenuItem>
                            <MenuItem Command="ApplicationCommands.Paste">

                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="帮助">
                            <MenuItem Header="操作帮助..." />
                            <MenuItem Header="关于..." Click="MenuAbout_Click" />
                        </MenuItem>
                    </Menu>
                    <TextBox Name="textBox1" Height="131" TextWrapping="Wrap" AcceptsReturn="True"
                Margin="10,10,10.333,10" Text="该文本框有一个快捷菜单。" >
                        <TextBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="粗体(_B)" IsChecked="True"
                            IsCheckable="True" Checked="Bold_Checked"
                            Unchecked="Bold_Unchecked" />
                                <MenuItem Header="斜体(_I)" IsCheckable="True"
                            Checked="Italic_Checked"
                            Unchecked="Italic_Unchecked" />
                            </ContextMenu>
                        </TextBox.ContextMenu>
                    </TextBox>
                </StackPanel>
            </GroupBox>

        </StackPanel>
    </Grid>
</Window>
