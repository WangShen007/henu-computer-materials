<Window x:Class="DataExampleWpfApp.ModifyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataExampleWpfApp"
        mc:Ignorable="d"
        Title="ModifyWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="159*"/>
            <ColumnDefinition Width="634*"/>
        </Grid.ColumnDefinitions>
        <Label Content="学号：" HorizontalAlignment="Left" Margin="75,85,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.746,-0.899"/>
        <Label Content="姓名：" HorizontalAlignment="Left" Margin="75,135,0,0" VerticalAlignment="Top"/>
        <Label Content="性别：" HorizontalAlignment="Left" Margin="75,187,0,0" VerticalAlignment="Top"/>
        <Label Content="出生日期" HorizontalAlignment="Left" Margin="75,247,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.43,-1.059"/>
        <TextBox Name="textBoxId"  HorizontalAlignment="Left" Height="23" Margin="3.596,85,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <TextBox Name="textBoxName" HorizontalAlignment="Left" Height="23" Margin="3.596,139,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <DatePicker  Name="datePickerBirthDate" HorizontalAlignment="Left" Margin="3.596,247,0,0" VerticalAlignment="Top" Width="120" Grid.Column="1"/>
        <Label Content="照片" HorizontalAlignment="Left" Margin="229.596,85,0,0" VerticalAlignment="Top" Grid.Column="1"/>
        <Image Name="image1" HorizontalAlignment="Left" Height="144" Margin="285.596,85,0,0" VerticalAlignment="Top" Width="185" OpacityMask="#FFF7CECE" Grid.Column="1" />
        <Button Content="导入照片" HorizontalAlignment="Left" Margin="250.596,247,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click" Grid.Column="1"/>
        <Button Content="移除照片" HorizontalAlignment="Left" Margin="371.596,247,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_1" Grid.Column="1"/>
        <Button Content="确定" HorizontalAlignment="Left" Margin="83.596,336,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_2" Grid.Column="1"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="229.596,336,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_3" Grid.Column="1"/>
        <ComboBox Name="comboxGender" Grid.Column="1" HorizontalAlignment="Left" Margin="3.667,187,0,0" VerticalAlignment="Top" Width="120">
            <ComboBoxItem Content="男"></ComboBoxItem>
            <ComboBoxItem Content="女"></ComboBoxItem>
        </ComboBox>

    </Grid>
</Window>
