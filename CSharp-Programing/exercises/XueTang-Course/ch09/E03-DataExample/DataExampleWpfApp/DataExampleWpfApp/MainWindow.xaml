<Window x:Class="DataExampleWpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataExampleWpfApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="350" Width="800">
    <StackPanel>
        <DataGrid Name="dataGrid1" AutoGenerateColumns="False"  Height="250" >
            <DataGrid.Columns>
                <DataGridTextColumn Header="学号" Binding="{Binding Xuehao}" />
                <DataGridTextColumn Header="姓名" Binding="{Binding Xingming}" />
                <DataGridTextColumn Header="性别" Binding="{Binding Xingbie}" />
                <DataGridTemplateColumn Header="出生日期" SortMemberPath="出生日期" CellTemplate="{StaticResource BirthDateTemplate}" />
                <DataGridTemplateColumn Header="照片" CellTemplate="{StaticResource PhotoTemplate}" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel HorizontalAlignment="Center" Margin="10">
            <Button Name="btnAdd" Content="添加" Margin="10 0" ToolTip="将详细信息作为新记录插入到数据库中" Click="btnAdd_Click"/>
            <Button Name="btnModify" Content="修改" Margin="10 0" ToolTip="将对详细信息的修改更新到数据库中" Click="btnModify_Click"/>
            <Button Name="btnDelete" Content="删除" Margin="10 0" ToolTip="删除当前选择的行" Click="btnDelete_Click" />
        </WrapPanel>
        
    </StackPanel>
</Window>
