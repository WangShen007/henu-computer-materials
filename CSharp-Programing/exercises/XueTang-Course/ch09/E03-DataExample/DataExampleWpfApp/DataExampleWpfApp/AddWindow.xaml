<Window x:Class="DataExampleWpfApp.AddWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DataExampleWpfApp"
        mc:Ignorable="d"
        Title="AddWindow" Height="450" Width="800">
    <Grid>
        <Label Content="学号：" HorizontalAlignment="Left" Margin="75,85,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.746,-0.899"/>
        <Label Content="姓名：" HorizontalAlignment="Left" Margin="75,135,0,0" VerticalAlignment="Top"/>
        <Label Content="性别：" HorizontalAlignment="Left" Margin="75,187,0,0" VerticalAlignment="Top"/>
        <Label Content="出生日期" HorizontalAlignment="Left" Margin="75,247,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.43,-1.059"/>
        <TextBox Name="textBoxId"  HorizontalAlignment="Left" Height="23" Margin="163,85,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <TextBox Name="textBoxName" HorizontalAlignment="Left" Height="23" Margin="163,139,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
        <ComboBox Name="comboxGender" HorizontalAlignment="Left" Margin="163,187,0,0" VerticalAlignment="Top" Width="120">
            <ComboBoxItem Content="男"></ComboBoxItem>
            <ComboBoxItem Content="女"></ComboBoxItem>
        </ComboBox>
        <DatePicker  Name="datePickerBirthDate" HorizontalAlignment="Left" Margin="163,247,0,0" VerticalAlignment="Top" Width="120"/>
        <Label Content="照片" HorizontalAlignment="Left" Margin="389,85,0,0" VerticalAlignment="Top"/>
        <Image Name="image1" HorizontalAlignment="Left" Height="144" Margin="445,85,0,0" VerticalAlignment="Top" Width="185" OpacityMask="#FFF7CECE" />
        <Button Content="导入照片" HorizontalAlignment="Left" Margin="410,247,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click"/>
        <Button Content="移除照片" HorizontalAlignment="Left" Margin="531,247,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_1"/>
        <Button Content="确定" HorizontalAlignment="Left" Margin="243,336,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_2"/>
        <Button Content="取消" HorizontalAlignment="Left" Margin="389,336,0,0" VerticalAlignment="Top" Width="75" Click="Button_Click_3"/>

    </Grid>
</Window>
