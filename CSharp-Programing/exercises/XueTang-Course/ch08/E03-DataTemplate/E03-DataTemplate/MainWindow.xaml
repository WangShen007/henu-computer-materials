<Window x:Class="E03_DataTemplate.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:E03_DataTemplate"
        mc:Ignorable="d"
    Title="MainWindow" Height="450" Width="800">
    <Window.Resources>
        <local:Book  x:Key="info" BookName="C#宝典" />
        <local:BookList x:Key="myBookList" ></local:BookList>
        <DataTemplate x:Key="BookListTemplate">
            <StackPanel Orientation="Horizontal">
                <TextBlock Margin="10 0 0 0" Text="{Binding Path=BookName}" />
                <TextBlock Margin="10 0 0 0" Text="{Binding Path=Description}" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>
    <Grid>
        <TextBlock FontSize="20" Margin="15,50,567,337" Text="{Binding Path=BookName,Source={StaticResource info}}"/>

        <ListBox Background="LightYellow" ItemsSource="{Binding Source={StaticResource myBookList}}" HorizontalAlignment="Left" Height="262" Margin="30,127,0,0" VerticalAlignment="Top" Width="330">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="10 0 0 0" Text="{Binding Path=BookName}" />
                        <TextBlock Margin="10 0 0 0" Text="{Binding Path=Description}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <ListBox Background="LightBlue" ItemsSource="{Binding Source={StaticResource myBookList}}" HorizontalAlignment="Left" Height="262" Margin="427,127,0,0" VerticalAlignment="Top" Width="330" ItemTemplate="{StaticResource BookListTemplate}">
        </ListBox>
        <Label FontSize="16" Content="方法一：直接在控件中定义数据模板" HorizontalAlignment="Left" Margin="47,85,0,0" VerticalAlignment="Top"/>
        <Label FontSize="16" Content="方法二：将数据模板创建为资源而后引用" HorizontalAlignment="Left" Margin="440,89,0,0" VerticalAlignment="Top" Width="302" RenderTransformOrigin="0.314,0.366"/>
    </Grid>
</Window>
