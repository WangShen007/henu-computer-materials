<Window x:Class="T06_01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T06_01"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF9CF9FF">
        <Label Content="文件路径:" HorizontalAlignment="Left" Margin="40,18,0,0" VerticalAlignment="Top" FontSize="20"/>
        <TextBox Name="FilePath_TextBox" HorizontalAlignment="Left" Margin="150,20,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="410" Height="35" FontSize="20"/>
        <Button Name="Browse_Button" Content="浏览" HorizontalAlignment="Left" Margin="585,18,0,0" VerticalAlignment="Top" Height="37" Width="65" FontSize="20" Click="Browse_Button_Click"/>
        <Button Name="LoadFile_Button" Content="读取文件" HorizontalAlignment="Left" Margin="675,18,0,0" VerticalAlignment="Top" Height="37" Width="90" FontSize="20" Click="LoadFile_Button_Click"/>
        <Button Name="SaveFile_Button" Content="保存文件" HorizontalAlignment="Center" Margin="0,378,0,0" VerticalAlignment="Top" Height="37" Width="140" FontSize="20" Click="SaveFile_Button_Click"/>
        <TextBox Name="ShowFile_TextBox" HorizontalAlignment="Center" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="780" Height="295" FontSize="20"/>

    </Grid>
</Window>
