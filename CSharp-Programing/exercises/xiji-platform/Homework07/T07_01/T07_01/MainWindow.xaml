<Window x:Class="T07_01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T07_01"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF40E1FF">
        <Label Content="用户名:" HorizontalAlignment="Left" Margin="250,97,0,0" VerticalAlignment="Top" Height="38" Width="73" FontSize="18"/>
        <TextBox Name="UserName" HorizontalAlignment="Left" Margin="355,97,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="180" Height="26"/>
        <Label Content="密码:" HorizontalAlignment="Left" Margin="250,144,0,0" VerticalAlignment="Top" Height="37" Width="55" FontSize="18"/>
        <PasswordBox Name="Password" HorizontalAlignment="Left" Margin="355,145,0,0" VerticalAlignment="Top" Width="180" Height="25"/>
        <Label Content="用户类型:" HorizontalAlignment="Left" Margin="250,186,0,0" VerticalAlignment="Top" Height="38" Width="91" FontSize="18"/>
        <ComboBox Name="Selection" HorizontalAlignment="Left" Margin="355,186,0,0" VerticalAlignment="Top" Width="180" Height="32" FontSize="18">
            <ComboBoxItem Tag="0" IsSelected="True" Content="一般用户"/>
            <ComboBoxItem Tag="1" Content="管理员"/>
        </ComboBox>
        <Button x:Name="Login" Content="登录" HorizontalAlignment="Left" Margin="278,255,0,0" VerticalAlignment="Top" Height="40" Width="78" Click="Login_Click"/>
        <Button x:Name="Cancel" Content="取消" HorizontalAlignment="Left" Margin="457,255,0,0" VerticalAlignment="Top" Height="40" Width="78" Click="Cancel_Click"/>


    </Grid>
</Window>
