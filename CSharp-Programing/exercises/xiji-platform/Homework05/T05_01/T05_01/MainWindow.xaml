<Window x:Class="T05_01.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:T05_01"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#FF8CE7D3">
        <TextBox Name="Search_TextBox" HorizontalAlignment="Center" Margin="0,343,0,0" TextWrapping="Wrap" Text="1" VerticalAlignment="Top" Width="120" Height="37" FontSize="24"/>
        <ListBox Name="Show_ListBox" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,0,0,135" Background="#FF51EFF4" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <Button Name="Show_Button" Content="显示" HorizontalAlignment="Left" Margin="220,341,0,0" VerticalAlignment="Top" Click="Show_Button_Click" Width="80" Height="39"/>
        <Button Name="Search_Button" Content="查找" HorizontalAlignment="Left" Margin="497,341,0,0" VerticalAlignment="Top" Width="98" Height="39" Click="Search_Button_Click"/>

    </Grid>
</Window>
