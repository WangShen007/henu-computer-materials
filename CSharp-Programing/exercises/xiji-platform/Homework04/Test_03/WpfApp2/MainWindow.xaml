<Window x:Class="WpfApp2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid Margin="10,10,10,218" Background="#FFCECECE">
            <Label Content="最小 :" HorizontalAlignment="Left" Margin="49,40,0,0" VerticalAlignment="Top"/>
            <TextBox Name="minValue" HorizontalAlignment="Left" Margin="94,44,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
            <Label Content="最大 :" HorizontalAlignment="Left" Margin="276,40,0,0" VerticalAlignment="Top"/>
            <TextBox Name="maxValue" HorizontalAlignment="Left" Margin="321,44,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="120"/>
            <Label Content="定时器间隔(秒) :" HorizontalAlignment="Left" Margin="49,99,0,0" VerticalAlignment="Top"/>
            <TextBox Name="intervalTime"  HorizontalAlignment="Left" Margin="154,103,0,0" TextWrapping="Wrap" Text="0.1" VerticalAlignment="Top" Width="120"/>
            <RadioButton Name="selectInteger" IsChecked="True" Content="随机生成整数" HorizontalAlignment="Left" Margin="605,43,0,0" VerticalAlignment="Top"/>
            <RadioButton Name="selectRealNumber" Content="随机生成实数" HorizontalAlignment="Left" Margin="605,109,0,0" VerticalAlignment="Top"/>
        </Grid>
        <Grid Margin="10,309,10,10" Background="#FFB1AEAE">
            <Label Name="result" Content="" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"  HorizontalAlignment="Center" VerticalAlignment="Center" Height="96" Width="760" FontSize="36" Background="{x:Null}" Foreground="#FF5FF0FA"/>
        </Grid>
        <Button Name="startButton" Content="开始" HorizontalAlignment="Left" Margin="215,255,0,0" VerticalAlignment="Top" Width="94" Click="Button_Click"/>
        <Button Name="stopButton" Content="停止" HorizontalAlignment="Left" Margin="387,255,0,0" VerticalAlignment="Top" Width="94" Click="Button_Click_1"/>

    </Grid>
</Window>
